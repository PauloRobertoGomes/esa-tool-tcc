# Copie este arquivo para .env.server e ajuste os valores abaixo
# Exemplo OCIR: gru.ocir.io/<namespace>/<repository>:latest
ESA_IMAGE=gru.ocir.io/seu-namespace/esa-tool:latest

# Porta exposta no host
APP_PORT=8000

# Ajuste para arquitetura do servidor
APP_PLATFORM=linux/amd64

# Limites para host pequeno (1 vCPU / 1GB)
APP_MEM_LIMIT=900m
APP_CPUS=1.0

# 0 = desliga keepalive no log | 1 = imprime ponto periodico
ESA_KEEPALIVE_DOT=0
